# Public site URL. Must match the domain configured in Supabase Auth redirects.
NEXT_PUBLIC_APP_URL=https://www.mshcode.com

# Supabase project endpoint and public anon key.
# If Supabase remains hosted outside Tencent Cloud, use the hosted project URL here.
NEXT_PUBLIC_SUPABASE_URL=https://lvinajipyscukaemiwys.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase service role key. Never expose this to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Optional server-side alias for tests/scripts and service clients.
SUPABASE_URL=https://lvinajipyscukaemiwys.supabase.co
SUPABASE_ANON_KEY=

# Keep mock until real WeChat Pay merchant, refunds, profit sharing and reconciliation are approved.
PAYMENT_PROVIDER=mock

# Optional order attachment upload limit. Defaults to 50 MB.
ORDER_FILE_MAX_BYTES=52428800

# Reserved for future real payment integration. Keep empty while PAYMENT_PROVIDER=mock.
WECHATPAY_MCH_ID=
WECHATPAY_APP_ID=
WECHATPAY_SERIAL_NO=
WECHATPAY_PRIVATE_KEY=
WECHATPAY_API_V3_KEY=
WECHATPAY_NOTIFY_URL=
